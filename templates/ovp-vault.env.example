# Example OVP vault environment for bid usage
# Save as: vault/.env

# Choose one compatible provider/model combination for OVP
# Volcengine Ark Coding Plan (OpenAI-compatible)
# AUTO_VAULT_API_KEY=your_ark_api_key_here
# AUTO_VAULT_API_BASE=https://ark.cn-beijing.volces.com/api/coding/v3
# AUTO_VAULT_MODEL=openai/ark-code-latest

# Standard OpenAI-compatible example
AUTO_VAULT_API_KEY=your_api_key_here
AUTO_VAULT_API_BASE=https://api.openai.com/v1
AUTO_VAULT_MODEL=openai/gpt-4o-mini

# Optional proxy
# HTTP_PROXY=http://127.0.0.1:7897

# Optional vault dir if needed by your setup
# WIGS_VAULT_DIR=/absolute/path/to/vault
